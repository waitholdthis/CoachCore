# Database
DATABASE_URL=postgresql+asyncpg://coachcore:coachcore@localhost:5432/coachcore
DATABASE_URL_SYNC=postgresql://coachcore:coachcore@localhost:5432/coachcore

# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embedding config
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# LLM config
LLM_MODEL=claude-sonnet-4-6
LLM_FAST_MODEL=claude-haiku-4-5-20251001

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# App
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# CoachCore Next.js
NEXT_PUBLIC_API_URL=http://localhost:8001

# The Season API
SEASON_DATABASE_URL=postgresql+asyncpg://season:season@localhost:5432/the_season
SEASON_DATABASE_URL_SYNC=postgresql://season:season@localhost:5432/the_season
SEASON_JWT_SECRET=change-me-in-production
SEASON_JWT_EXPIRE_MINUTES=10080
SEASON_DEMO_PASSWORD=change-this-local-demo-password
CORS_ORIGINS=http://localhost:3002

# The Season web app
SEASON_API_INTERNAL_URL=http://localhost:8002

# File/Object storage for The Season
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=the-season
MINIO_USE_SSL=false
